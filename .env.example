# Database
DATABASE_URL="mysql://root:root@127.0.0.1:3306/syllabus_db"

# Auth.js v5 — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-openssl-rand-base64-32"

# Google OAuth — see docs/SETUP_GUIDE.md Step 4b
AUTH_GOOGLE_ID="your-google-oauth-client-id"
AUTH_GOOGLE_SECRET="your-google-oauth-client-secret"
AUTH_TRUST_HOST=true

# Production only — see .env.production.example for all production vars
# DOMAIN="yourdomain.com"
# DB_ROOT_PASSWORD="strong-password"
# DB_PASSWORD="strong-password"
# NEXTAUTH_URL="https://yourdomain.com"

# GitHub Actions secrets (set in repo Settings → Secrets and Variables → Actions):
# SSH_HOST         — Server IP or domain
# SSH_USER         — SSH username (e.g., deploy)
# SSH_KEY          — Private SSH key for deployment
# DB_ROOT_PASSWORD — MySQL root password
# DB_PASSWORD      — MySQL app user password
# DOMAIN           — Your domain name (e.g., syllabus.yourdomain.com)
#
# Future (when auth is added):
# AUTH_SECRET, AUTH_GOOGLE_ID, AUTH_GOOGLE_SECRET, NEXTAUTH_URL